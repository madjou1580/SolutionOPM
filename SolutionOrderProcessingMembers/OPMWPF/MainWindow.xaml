<Window x:Class="OPMWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OPMWPF"
        mc:Ignorable="d"
        Title="Order Processing Members" Height="650" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Order Processing Members"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- LOGIN -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Email:" VerticalAlignment="Center" Width="60"/>
            <TextBox x:Name="txtEmail" Width="250" Height="28" Margin="0,0,10,0"/>
            <Button x:Name="btnLogin" Content="Login" Width="100" Height="30" Click="btnLogin_Click"/>
            <Button x:Name="btnControl" Content="Controle Scherm" Width="140" Height="30" Margin="15,0,0,0" Click="btnControl_Click"/>
        </StackPanel>

        <!-- MEMBER INFO -->
        <GroupBox Header="Member Info" Grid.Row="2" Margin="0,0,0,20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Member:" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtMemberInfo"
                       FontSize="16"
                       Text="Geen lid ingelogd."
                       TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Events:" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListBox x:Name="lstEvents" Height="130"/>
                </StackPanel>
              
            </Grid>
        </GroupBox>

        <!-- ORDER RESULT -->
        <GroupBox Header="Order Result" Grid.Row="3" Margin="0,0,0,20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Button x:Name="btnCreateOrder" Content="Create Order"
                            Width="150" Height="35"
                            Click="btnCreateOrder_Click"/>
                    <TextBlock x:Name="txtPrice" Margin="0,20,0,0" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="txtDeliveryType" Margin="0,10,0,0" FontSize="14"/>
                    <TextBlock x:Name="txtWelcomePackage" Margin="0,5,0,0" FontSize="14"/>
                    <TextBlock x:Name="txtNameTag" Margin="0,5,0,0" FontSize="14"/>
                    <TextBlock x:Name="txtExtraServices" Margin="0,10,0,0" FontSize="14" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Products:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ListBox x:Name="lstProducts"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="4" Text="WPF Version - OPM Project"
                   HorizontalAlignment="Right" Foreground="Gray"/>
    </Grid>
</Window>
